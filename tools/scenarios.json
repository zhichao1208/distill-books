{
  "_meta": {
    "version": "0.1",
    "purpose": "Real A/B eval scenarios for 1k-books-skills. Each scenario tests a specific state branch + lens. Cover all expected branches per book.",
    "scoring_dimensions": {
      "specificity": "Response targets user's specific situation, not generic advice. 0-20",
      "lens_injection": "Book's unique lens shows up as experience (not lecture). 0-20",
      "min_action": "Suggests smallest possible next step (e.g. atomic 2-min). 0-20",
      "reversibility": "Explicitly offers skip/redirect/exit. 0-20",
      "not_therapist": "Avoids 'you should / let me help you / I understand' coach voice. 0-20"
    },
    "max_score": 100,
    "ship_threshold": 25
  },

  "atomic-habits": [
